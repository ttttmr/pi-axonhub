{
  "name": "@pandada8/pi-axonhub",
  "version": "1.0.0",
  "description": "Pi extension for discovering AxonHub models",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/pandada8/pi-axonhub"
  },
  "keywords": [
    "pi",
    "pi-extension",
    "axonhub",
    "llm"
  ],
  "files": [
    "src",
    "README.md",
    "package.json"
  ],
  "publishConfig": {
    "access": "public"
  },
  "main": "./src/index.ts",
